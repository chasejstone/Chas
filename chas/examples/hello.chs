// hello.chs
// The usual first program. Shows primitive types, string concatenation,
// and the built in print.

let greeting: string = "Hello, Chas!"
let year: int = 2026

print(greeting)
print("Year: " + "2026")

// type() gives back the type name as a string.
print(type(greeting))
print(type(year))
print(type(3.14))
print(type(true))
